# 复制本文件为 .env.local 并填入真实值（.env.local 勿提交到 Git）

# 生产环境（阿里云等）：仅白名单 IP 可编辑，且编辑会自动发布到服务器 data/published-site.json，访客才能看到最新简历
# 查看本机公网 IP：部署后访问 https://你的域名/api/my-ip
# ALLOWED_EDIT_IPS=1.2.3.4,5.6.7.8

# 可选：发布快照路径（默认项目根目录 data/published-site.json，需 Node 进程可写）
# SITE_PUBLISH_PATH=data/published-site.json

# 可选：分享 →「发送到邮箱」由服务器代发（https://resend.com 注册后获取 API Key）
# 未配置时，页面「发送」会自动改为打开本机邮件客户端（mailto）
RESEND_API_KEY=

# 可选：Resend 后台已验证的发件人；不填则使用 Resend 默认测试域（有收件限制）
# RESEND_FROM=你的名字 <noreply@你的域名.com>

# 可选：简历智能解析 — DeepSeek（推荐，按量计费）
# 1. 在 https://platform.deepseek.com 创建 API Key
# 2. 把密钥填到下面 OPENAI_API_KEY（变量名沿用 OpenAI 兼容格式，填 DeepSeek 的 Key 即可）
# 3. 重启 npm run dev；导入弹窗应显示「DeepSeek · deepseek-chat」
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
RESUME_PARSE_MODEL=deepseek-chat

# 若使用官方 OpenAI，可改为：
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# RESUME_PARSE_MODEL=gpt-4o-mini

# 正式站点域名：分享、EditURL、ViewURL 一律使用此外网地址（本地 localhost 调试时也会生成此域名链接）
NEXT_PUBLIC_SITE_URL=https://linkola.cn
# SITE_PUBLIC_URL=https://linkola.cn

# 商用多客户模式：创建“可编辑链接 + HR只读链接”时使用的管理员密钥（调用 POST /api/resume-space）
# RESUME_SPACE_ADMIN_KEY=replace-with-a-strong-secret
